# Machine-specific Claude Code settings
.claude/

# macOS
.DS_Store
**/.DS_Store

# Backup files (any extension after .bak counts — e.g. .bak.20260518-123431)
*.bak
*.bak.*
*.backup
*.before-*
*~

# Tmux plugins (managed by TPM at runtime)
tmux/.config/tmux/.tmux/plugins/

# Tmux plugin intermediate files
tmux/.config/tmux/.pi/

# MCP server config (machine-specific, uses env var references)
.mcp.json

# Local overrides (create these for machine-specific config)
*.local

# Zsh compinit cache (regenerated per-shell)
.zcompdump*

# macOS LaunchAgent log files
Library/Logs/

# Rendered LaunchAgent plists (templates live under launchagents/, rendered
# plists are copied to ~/Library/LaunchAgents/ at install time by setup.sh)
launchagents/.rendered/

# Rendered AeroSpace config (template lives at aerospace.toml.template,
# render-aerospace.sh produces aerospace.toml from personal.env at install time)
aerospace/.config/aerospace/aerospace.toml

# w3m runtime state — live session cookies/history/bookmarks must never be
# tracked (~/.w3m symlinks into the repo, so w3m writes them into the tree).
# Structural fix would be `stow --no-folding` for the w3m package.
w3m/.w3m/cookie
w3m/.w3m/history
w3m/.w3m/request.log
w3m/.w3m/bookmark.html
w3m/.w3m/pre_form
w3m/.w3m/w3mcache*

# mpd runtime state — mpd.conf points these at ~/.local/state/mpd/, but keep
# the repo dir clean if an old daemon writes here through the stow symlink
mpd/.config/mpd/database
mpd/.config/mpd/state
mpd/.config/mpd/sticker.sql
mpd/.config/mpd/mpd.log
mpd/.config/mpd/pid
mpd/.config/mpd/mpd.db
mpd/.config/mpd/mpd.pid
mpd/.config/mpd/mpdstate

# DuranteOS internal state
.dos/

# Karabiner-Elements auto-generated config backups (machine-local, timestamped)
karabiner/.config/karabiner/automatic_backups/

# Sentinel scan scratch (scan-report.json, conventions.json, health.json).
# Curated artifacts live in docs/Sentinel/ and are tracked; .sentinel/ is machine-local.
.sentinel/

# Memory palace runtime state
.mempalace/

# DOS session-state spill (baselines, intel-context cache, fired events).
# Surfaces in the repo root when an agent runs here; nothing in MEMORY/ is
# meant to be tracked. Different from the curated MEMORY/WORK/ tree that
# lives under ~/Durante.
MEMORY/

# Claude Code transcript dumps (ad-hoc, not source of truth)
dotfiles-conversation.txt
