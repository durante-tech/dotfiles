# Place a copy of this config to ~/.aerospace.toml
# After that, you can edit ~/.aerospace.toml to your liking

# It's not necessary to copy all keys to your config.
# If the key is missing in your config, "default-config.toml" will serve as a fallback

# Config version for compatibility and deprecations (max is 2; omitting = 1).
# v2 makes persistent-workspaces explicit instead of inferred from keybinding
# right-hand sides — required here because the E/N workspace bindings are
# commented out (Brazilian accents) yet on-window-detected still routes apps
# to E and N. See: https://nikitabobko.github.io/AeroSpace/guide#config-version
config-version = 2

# You can use it to add commands that run after login to macOS user session.
# 'start-at-login' needs to be 'true' for 'after-login-command' to work
# Available commands: https://nikitabobko.github.io/AeroSpace/commands
after-login-command = []

# You can use it to add commands that run after AeroSpace startup.
# 'after-startup-command' is run after 'after-login-command'
# Available commands : https://nikitabobko.github.io/AeroSpace/commands
after-startup-command = [
  'exec-and-forget sketchybar',
  # JankyBorders: only draw on focused window. Transparent inactive_color
  # prevents borders from being drawn around tile-hidden windows on other
  # workspaces (which otherwise bleed into the bottom-left as a sliver).
  'exec-and-forget borders active_color=0xff8aadf4 inactive_color=0x00000000 width=4.0'
]

# Notify Sketchybar about workspace change AND swap per-workspace wallpaper.
# wallpaper-workspace.sh looks for ~/Pictures/Wallpapers/workspace-<NAME>.{jpg,png}
# with a graceful fallback chain — missing files are a no-op, never a crash.
exec-on-workspace-change = ['/bin/bash', '-c',
    'sketchybar --trigger aerospace_workspace_change FOCUSED_WORKSPACE=$AEROSPACE_FOCUSED_WORKSPACE; ~/scripts/wallpaper-workspace.sh "$AEROSPACE_FOCUSED_WORKSPACE" &'
]

# Notify when mode changes (v0.19+) - useful for visual feedback
# This runs AeroSpace commands when switching modes (e.g., entering resize mode)
# To trigger external scripts, use exec-and-forget:
# on-mode-changed = ['exec-and-forget sketchybar --trigger mode_change MODE=$AEROSPACE_MODE']
# For now, we leave it empty - uncomment above line if you add mode indicator to sketchybar
on-mode-changed = ['exec-and-forget sketchybar --trigger aerospace_mode_change MODE=$AEROSPACE_MODE']

# Start AeroSpace at login
start-at-login = true

# Unhide hidden apps when focusing them
automatically-unhide-macos-hidden-apps = true

# Workspaces that stay alive even when empty (needs config-version = 2;
# rationale in the config-version comment above). Keep in sync with the
# bindings, [workspace-to-monitor-force-assignment], and on-window-detected
# rules below when adding or removing a workspace.
persistent-workspaces = ['1', '2', 'A', 'B', 'D', 'E', 'F', 'M', 'N', 'T']

# Normalizations. See: https://nikitabobko.github.io/AeroSpace/guide#normalization
enable-normalization-flatten-containers = true
enable-normalization-opposite-orientation-for-nested-containers = true

# See: https://nikitabobko.github.io/AeroSpace/guide#layouts
# The 'accordion-padding' specifies the size of accordion padding
# You can set 0 to disable the padding feature
accordion-padding = 30

# Possible values: tiles|accordion
default-root-container-layout = 'tiles'

# Possible values: horizontal|vertical|auto
# 'auto' means: wide monitor (anything wider than high) gets horizontal orientation,
#               tall monitor (anything higher than wide) gets vertical orientation
default-root-container-orientation = 'auto'

# Possible values: (qwerty|dvorak)
# See https://nikitabobko.github.io/AeroSpace/guide#key-mapping
key-mapping.preset = 'qwerty'
# Mouse follows focus when focused monitor changes
# Drop it from your config, if you don't like this behavior
# See https://nikitabobko.github.io/AeroSpace/guide#on-focus-changed-callbacks
# See https://nikitabobko.github.io/AeroSpace/commands#move-mouse
# on-focus-changed = "move-mouse window-lazy-center"
on-focused-monitor-changed = ['move-mouse monitor-lazy-center']

# Gaps between windows (inner-*) and between monitor edges (outer-*).
# Possible values:
# - Constant:     gaps.outer.top = 8
# - Per monitor:  gaps.outer.top = [{ monitor.main = 16 }, { monitor."some-pattern" = 32 }, 24]
#                 In this example, 24 is a default value when there is no match.
#                 Monitor pattern is the same as for 'workspace-to-monitor-force-assignment'.
#                 See: https://nikitabobko.github.io/AeroSpace/guide#assign-workspaces-to-monitors
[gaps]
# Per-monitor gaps. Built-in Retina (14") gets tighter to recover screen real
# estate; PORTRAIT (Dell 4K rotated) keeps the breathier 15px because there's
# more pixel headroom and the eye expects more breathing room on a 27" panel.
inner.horizontal = [
  { monitor."@DOTFILES_MONITOR_BUILTIN@" = 10 },
  { monitor."@DOTFILES_MONITOR_EXTERNAL@" = 15 },
  15,
]
inner.vertical = [
  { monitor."@DOTFILES_MONITOR_BUILTIN@" = 10 },
  { monitor."@DOTFILES_MONITOR_EXTERNAL@" = 15 },
  15,
]
outer.left = [
  { monitor."@DOTFILES_MONITOR_BUILTIN@" = 10 },
  { monitor."@DOTFILES_MONITOR_EXTERNAL@" = 15 },
  15,
]
outer.right = [
  { monitor."@DOTFILES_MONITOR_BUILTIN@" = 10 },
  { monitor."@DOTFILES_MONITOR_EXTERNAL@" = 15 },
  15,
]
outer.bottom = [
  { monitor."@DOTFILES_MONITOR_BUILTIN@" = 15 },
  { monitor."@DOTFILES_MONITOR_EXTERNAL@" = 15 },
  15,
]
# Per-monitor top gap. Sketchybar (height=28) self-reserves its strip, so this is
# pure padding below the bar — not bar clearance. Built-in at 10 matches its 10px
# side gaps (snug, balanced vs the 15px bottom); PORTRAIT keeps 50 for its scale.
outer.top = [
  { monitor."@DOTFILES_MONITOR_BUILTIN@" = 10 },
  { monitor."@DOTFILES_MONITOR_EXTERNAL@" = 50 },
  15,
]

# Pin key workspaces to monitors
# See: https://nikitabobko.github.io/AeroSpace/guide#assign-workspaces-to-monitors
[workspace-to-monitor-force-assignment]
# Built-in display can't be renamed in BetterDisplay, use actual macOS name.
# Each value is a fallback chain — first matching pattern wins, and the
# terminal 'main' guarantees a match on any hardware. Degradation by monitor
# count when the named pattern doesn't match: 1 monitor -> everything on it;
# 2 monitors -> 'secondary' keeps external-pinned workspaces off the laptop
# screen; 3+ monitors -> 'secondary' does NOT resolve (AeroSpace defines it
# only for exactly two monitors), so unmatched pins land on 'main' — run
# ./personalize.sh to pin exact names on 3+-monitor rigs.
1 = ['@DOTFILES_MONITOR_BUILTIN@', 'main']                   # Main workspace on laptop
2 = ['^@DOTFILES_MONITOR_EXTERNAL@$', 'secondary', 'main']   # Secondary workspace on portrait
A = ['@DOTFILES_MONITOR_BUILTIN@', 'main']                   # AI engineer apps (Claude, Codex) on laptop
B = ['^@DOTFILES_MONITOR_EXTERNAL@$', 'secondary', 'main']   # Browser on portrait
D = ['@DOTFILES_MONITOR_BUILTIN@', 'main']                   # Development on laptop
E = ['@DOTFILES_MONITOR_BUILTIN@', 'main']                   # Email on laptop
F = ['@DOTFILES_MONITOR_BUILTIN@', 'main']                   # Finder on laptop (floats)
M = ['@DOTFILES_MONITOR_BUILTIN@', 'main']                   # Messaging on laptop
N = ['@DOTFILES_MONITOR_BUILTIN@', 'main']                   # Notes on laptop
T = ['^@DOTFILES_MONITOR_EXTERNAL@$', 'secondary', 'main']   # Terminal on portrait
# 'main' binding mode declaration
# See: https://nikitabobko.github.io/AeroSpace/guide#binding-modes
# 'main' binding mode must be always presented
[mode.main.binding]

# All possible keys:
# - Letters.        a, b, c, ..., z
# - Numbers.        0, 1, 2, ..., 9
# - Keypad numbers. keypad0, keypad1, keypad2, ..., keypad9
# - F-keys.         f1, f2, ..., f20
# - Special keys.   minus, equal, period, comma, slash, backslash, quote, semicolon, backtick,
#                   leftSquareBracket, rightSquareBracket, space, enter, esc, backspace, tab
# - Keypad special. keypadClear, keypadDecimalMark, keypadDivide, keypadEnter, keypadEqual,
#                   keypadMinus, keypadMultiply, keypadPlus
# - Arrows.         left, down, up, right

# All possible modifiers: cmd, alt, ctrl, shift

# All possible commands: https://nikitabobko.github.io/AeroSpace/commands

# You can uncomment this line to open up terminal with alt + enter shortcut
# See: https://nikitabobko.github.io/AeroSpace/commands#exec-and-forget
# alt-enter = 'exec-and-forget open -n /System/Applications/Utilities/Terminal.app'

# See: https://nikitabobko.github.io/AeroSpace/commands#layout
alt-slash = 'layout tiles horizontal vertical'
alt-comma = 'layout accordion horizontal vertical'
alt-period = 'layout floating tiling'
alt-shift-space = 'fullscreen'
alt-r = 'reload-config'
# alt-s sketchybar toggle moved to Karabiner (Ctrl+Shift+\) — terminals swallow Option key
alt-0 = 'workspace-back-and-forth'
alt-shift-c = 'close'
alt-enter = '''exec-and-forget open -na /Applications/Ghostty.app'''

# See: https://nikitabobko.github.io/AeroSpace/commands#focus
alt-h = 'focus --boundaries-action wrap-around-the-workspace left'
alt-j = 'focus --boundaries-action wrap-around-the-workspace down'
alt-k = 'focus --boundaries-action wrap-around-the-workspace up'
alt-l = 'focus --boundaries-action wrap-around-the-workspace right'

# See: https://nikitabobko.github.io/AeroSpace/commands#move
alt-shift-h = 'move left'
alt-shift-j = 'move down'
alt-shift-k = 'move up'
alt-shift-l = 'move right'
alt-shift-minus = 'resize smart -50'
alt-shift-equal = 'resize smart +50'

# Swap windows (v0.19+): exchange position with adjacent window
# See: https://nikitabobko.github.io/AeroSpace/commands#swap
alt-ctrl-h = 'swap left'
alt-ctrl-j = 'swap down'
alt-ctrl-k = 'swap up'
alt-ctrl-l = 'swap right'

# DFS Navigation (v0.19+): cycle through ALL windows depth-first
# Useful for quickly cycling when you have many windows
# See: https://nikitabobko.github.io/AeroSpace/commands#focus
alt-rightSquareBracket = 'focus dfs-next'
alt-leftSquareBracket = 'focus dfs-prev'
# See: https://nikitabobko.github.io/AeroSpace/commands#workspace
alt-1 = 'workspace 1'
alt-2 = 'workspace 2'
# alt-3 = 'workspace 3'
# alt-4 = 'workspace 4'
# alt-5 = 'workspace 5'
# alt-6 = 'workspace 6'
# alt-7 = 'workspace 7'
# alt-8 = 'workspace 8'
# alt-9 = 'workspace 9'
alt-a = 'workspace A' # for AI engineer apps (Claude, Codex) — also fires on Caps+A via Karabiner Hyper→alt rewrite
alt-b = 'workspace B' # for browser
# Unbound by design: alt-e is the pt-BR acute-accent dead key. Workspace E is
# reached via Karabiner Hyper+E and kept alive by persistent-workspaces above.
# alt-e = 'workspace E' # for email
alt-f = 'workspace F' # for finder
alt-d = 'workspace D' # for development
alt-m = 'workspace M' #
# Unbound by design: alt-n is the pt-BR tilde dead key. Workspace N is
# reached via Karabiner Hyper+N and kept alive by persistent-workspaces above.
# alt-n = 'workspace N' # for notes
# alt-p = 'workspace P'
alt-t = 'workspace T' # for terminal shell
# alt-v = 'workspace V'

# See: https://nikitabobko.github.io/AeroSpace/commands#move-node-to-workspace
alt-shift-1 = 'move-node-to-workspace 1'
alt-shift-2 = 'move-node-to-workspace 2'
# alt-shift-3 = 'move-node-to-workspace 3'
# alt-shift-4 = 'move-node-to-workspace 4'
# alt-shift-5 = 'move-node-to-workspace 5'
# alt-shift-6 = 'move-node-to-workspace 6'
# alt-shift-7 = 'move-node-to-workspace 7'
# alt-shift-8 = 'move-node-to-workspace 8'
# alt-shift-9 = 'move-node-to-workspace 9'
alt-shift-a = 'move-node-to-workspace A'
alt-shift-b = 'move-node-to-workspace B'
# Unbound by design (pt-BR acute dead key) — move windows to E via
# on-window-detected rules or `aerospace move-node-to-workspace E`.
# alt-shift-e = 'move-node-to-workspace E'
alt-shift-f = 'move-node-to-workspace F'
alt-shift-d = 'move-node-to-workspace D'
alt-shift-m = 'move-node-to-workspace M'
# Unbound by design (pt-BR tilde dead key) — move windows to N via
# on-window-detected rules or `aerospace move-node-to-workspace N`.
# alt-shift-n = 'move-node-to-workspace N'
# alt-shift-p = 'move-node-to-workspace P'
alt-shift-t = 'move-node-to-workspace T'
# alt-shift-v = 'move-node-to-workspace V'
# See: https://nikitabobko.github.io/AeroSpace/commands#workspace-back-and-forth
alt-tab = 'workspace-back-and-forth'
# See: https://nikitabobko.github.io/AeroSpace/commands#move-workspace-to-monitor
alt-shift-tab = 'move-workspace-to-monitor --wrap-around next'

# See: https://nikitabobko.github.io/AeroSpace/commands#mode
# Original alt-shift-semicolon entry was commented out for Brazilian accents;
# alt-shift-s is accent-safe (pt-BR accents use Option dead keys, not
# Option+Shift+letter) and mnemonic: s = service.
alt-shift-s = 'mode service'

alt-shift-r = 'mode resize'
alt-shift-x = 'mode bd-mode'

[mode.resize.binding]
# Fine control (50px)
h = 'resize width -50'
j = 'resize height +50'
k = 'resize height -50'
l = 'resize width +50'

# Coarse control (200px)
shift-h = 'resize width -200'
shift-j = 'resize height +200'
shift-k = 'resize height -200'
shift-l = 'resize width +200'

b = 'balance-sizes'

# Exit resize mode
enter = 'mode main'
esc = 'mode main'
# 'service' binding mode declaration.
# See: https://nikitabobko.github.io/AeroSpace/guide#binding-modes
[mode.service.binding]
esc = ['reload-config', 'mode main']
r = ['flatten-workspace-tree', 'mode main'] # reset layout
#s = ['layout sticky tiling', 'mode main'] # sticky is not yet supported https://github.com/nikitabobko/AeroSpace/issues/2
f = [
  'layout floating tiling',
  'mode main',
] # Toggle between floating and tiling layout
backspace = ['close-all-windows-but-current', 'mode main']

alt-shift-h = ['join-with left', 'mode main']
alt-shift-j = ['join-with down', 'mode main']
alt-shift-k = ['join-with up', 'mode main']
alt-shift-l = ['join-with right', 'mode main']

# BetterDisplay mode-switching chord. Entry: alt-shift-x. Single key picks the mode.
[mode.bd-mode.binding]
# AeroSpace's exec-and-forget runs commands directly (no shell). @DOTFILES_DIR@
# is substituted with the absolute repo path by render-aerospace.sh at render
# time — do NOT swap it for a runtime env var; the rendered aerospace.toml is a
# static file with no further substitution. /bin/bash -c wrap kept for shell
# semantics of the invoked script.
w = ['exec-and-forget /bin/bash -c "@DOTFILES_DIR@/scripts/scripts/bd-apply.sh dawn"', 'mode main']
d = ['exec-and-forget /bin/bash -c "@DOTFILES_DIR@/scripts/scripts/bd-apply.sh day"', 'mode main']
a = ['exec-and-forget /bin/bash -c "@DOTFILES_DIR@/scripts/scripts/bd-apply.sh afternoon"', 'mode main']
e = ['exec-and-forget /bin/bash -c "@DOTFILES_DIR@/scripts/scripts/bd-apply.sh evening"', 'mode main']
n = ['exec-and-forget /bin/bash -c "@DOTFILES_DIR@/scripts/scripts/bd-apply.sh night"', 'mode main']
m = ['exec-and-forget /bin/bash -c "@DOTFILES_DIR@/scripts/scripts/bd-apply.sh meeting"', 'mode main']
r = ['exec-and-forget /bin/bash -c "@DOTFILES_DIR@/scripts/scripts/bd-apply.sh read"', 'mode main']
s = ['exec-and-forget /bin/bash -c "@DOTFILES_DIR@/scripts/scripts/bd-apply.sh stream"', 'mode main']
c = ['exec-and-forget /bin/bash -c "@DOTFILES_DIR@/scripts/scripts/bd-apply.sh cinema"', 'mode main']
esc = 'mode main'
enter = 'mode main'

