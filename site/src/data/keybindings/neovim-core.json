{
  "id": "neovim-core",
  "title": "Neovim Core",
  "description": "Essential motions, modes, and basic editing",
  "drills": [
    { "keys": "i", "action": "Enter Insert mode", "context": "Normal mode", "category": "modes", "difficulty": 1, "mnemonic": "i for insert" },
    { "keys": "Escape", "action": "Return to Normal mode", "context": "Insert mode", "category": "modes", "difficulty": 1, "mnemonic": "Escape always returns to Normal" },
    { "keys": "v", "action": "Enter Visual mode", "context": "Normal mode", "category": "modes", "difficulty": 1, "mnemonic": "v for visual" },
    { "keys": "V", "action": "Enter Visual Line mode", "context": "Normal mode", "category": "modes", "difficulty": 2, "mnemonic": "Capital V selects whole lines" },
    { "keys": ":", "action": "Enter Command mode", "context": "Normal mode", "category": "modes", "difficulty": 1, "mnemonic": "Colon starts commands" },
    { "keys": "w", "action": "Move to next word", "context": "Normal mode", "category": "motion", "difficulty": 1, "mnemonic": "w for word forward" },
    { "keys": "b", "action": "Move to previous word", "context": "Normal mode", "category": "motion", "difficulty": 1, "mnemonic": "b for back" },
    { "keys": "e", "action": "Move to end of word", "context": "Normal mode", "category": "motion", "difficulty": 1, "mnemonic": "e for end" },
    { "keys": "0", "action": "Move to start of line", "context": "Normal mode", "category": "motion", "difficulty": 1, "mnemonic": "0 is the beginning" },
    { "keys": "$", "action": "Move to end of line", "context": "Normal mode", "category": "motion", "difficulty": 1, "mnemonic": "$ like regex end-of-line" },
    { "keys": "gg", "action": "Go to first line", "context": "Normal mode", "category": "motion", "difficulty": 1, "mnemonic": "gg = go go to top" },
    { "keys": "G", "action": "Go to last line", "context": "Normal mode", "category": "motion", "difficulty": 1, "mnemonic": "Capital G = bottom" },
    { "keys": "Ctrl+d", "action": "Half page down", "context": "Normal mode", "category": "motion", "difficulty": 2, "mnemonic": "d for down" },
    { "keys": "Ctrl+u", "action": "Half page up", "context": "Normal mode", "category": "motion", "difficulty": 2, "mnemonic": "u for up" },
    { "keys": "dd", "action": "Delete current line", "context": "Normal mode", "category": "editing", "difficulty": 1, "mnemonic": "dd = delete line (doubled operators act on line)" },
    { "keys": "yy", "action": "Yank (copy) current line", "context": "Normal mode", "category": "editing", "difficulty": 1, "mnemonic": "yy = yank line" },
    { "keys": "p", "action": "Paste after cursor", "context": "Normal mode", "category": "editing", "difficulty": 1, "mnemonic": "p for paste" },
    { "keys": "u", "action": "Undo", "context": "Normal mode", "category": "editing", "difficulty": 1, "mnemonic": "u for undo" },
    { "keys": "Ctrl+r", "action": "Redo", "context": "Normal mode", "category": "editing", "difficulty": 2, "mnemonic": "r for redo" },
    { "keys": "o", "action": "Open new line below", "context": "Normal mode", "category": "editing", "difficulty": 1, "mnemonic": "o for open" },
    { "keys": "O", "action": "Open new line above", "context": "Normal mode", "category": "editing", "difficulty": 1, "mnemonic": "Capital O = above" },
    { "keys": "A", "action": "Append at end of line", "context": "Normal mode", "category": "editing", "difficulty": 2, "mnemonic": "A = append at end" },
    { "keys": "I", "action": "Insert at beginning of line", "context": "Normal mode", "category": "editing", "difficulty": 2, "mnemonic": "I = insert at start" },
    { "keys": "x", "action": "Delete character under cursor", "context": "Normal mode", "category": "editing", "difficulty": 1, "mnemonic": "x marks deletion" },
    { "keys": ".", "action": "Repeat last change", "context": "Normal mode", "category": "editing", "difficulty": 2, "mnemonic": "Dot repeats the last edit" },
    { "keys": "/", "action": "Search forward", "context": "Normal mode", "category": "search", "difficulty": 1, "mnemonic": "/ starts a forward search" },
    { "keys": "n", "action": "Next search match", "context": "Normal mode", "category": "search", "difficulty": 1, "mnemonic": "n for next" },
    { "keys": "N", "action": "Previous search match", "context": "Normal mode", "category": "search", "difficulty": 1, "mnemonic": "N for previous (reverse)" },
    { "keys": "*", "action": "Search word under cursor", "context": "Normal mode", "category": "search", "difficulty": 2, "mnemonic": "Star highlights the word" },
    { "keys": ":w", "action": "Save file", "context": "Command mode", "category": "file", "difficulty": 1, "mnemonic": "w for write" },
    { "keys": ":q", "action": "Quit", "context": "Command mode", "category": "file", "difficulty": 1, "mnemonic": "q for quit" },
    { "keys": ":wq", "action": "Save and quit", "context": "Command mode", "category": "file", "difficulty": 1, "mnemonic": "write then quit" }
  ]
}
