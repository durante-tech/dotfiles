{
  "id": "tmux-core",
  "title": "Tmux Core",
  "description": "Sessions, windows, panes, and copy mode",
  "drills": [
    { "keys": "Ctrl+b |", "action": "Split pane horizontally", "context": "Tmux", "category": "panes", "difficulty": 1, "mnemonic": "Pipe splits vertically (visually)" },
    { "keys": "Ctrl+b -", "action": "Split pane vertically", "context": "Tmux", "category": "panes", "difficulty": 1, "mnemonic": "Dash splits horizontally" },
    { "keys": "Ctrl+b m", "action": "Maximize/restore pane (zoom)", "context": "Tmux", "category": "panes", "difficulty": 2, "mnemonic": "m for maximize" },
    { "keys": "Ctrl+b D", "action": "Detach from session", "context": "Tmux", "category": "session", "difficulty": 2, "mnemonic": "D for detach" },
    { "keys": "Ctrl+b f", "action": "Tmux sessionizer (FZF picker)", "context": "Tmux", "category": "session", "difficulty": 2, "mnemonic": "f for find session" },
    { "keys": "Ctrl+b n", "action": "New session with name", "context": "Tmux", "category": "session", "difficulty": 2, "mnemonic": "n for new" },
    { "keys": "Ctrl+b o", "action": "SessionX session switcher", "context": "Tmux", "category": "session", "difficulty": 2, "mnemonic": "o for open sessions" },
    { "keys": "Ctrl+b v", "action": "Enter copy mode", "context": "Tmux", "category": "copy", "difficulty": 2, "mnemonic": "v for visual (like vim)" },
    { "keys": "Ctrl+b r", "action": "Reload tmux config", "context": "Tmux", "category": "config", "difficulty": 1, "mnemonic": "r for reload" },
    { "keys": "Ctrl+b Ctrl+g", "action": "Open lazygit (floating)", "context": "Tmux", "category": "floating", "difficulty": 2, "mnemonic": "g for git" },
    { "keys": "Ctrl+b Ctrl+y", "action": "Open Yazi (floating)", "context": "Tmux", "category": "floating", "difficulty": 2, "mnemonic": "y for yazi" },
    { "keys": "Ctrl+b Ctrl+t", "action": "Quick terminal (floating)", "context": "Tmux", "category": "floating", "difficulty": 2, "mnemonic": "t for terminal" },
    { "keys": "Ctrl+b H", "action": "Resize pane left", "context": "Tmux", "category": "panes", "difficulty": 3, "mnemonic": "vim-style hjkl resize" },
    { "keys": "Ctrl+b L", "action": "Resize pane right", "context": "Tmux", "category": "panes", "difficulty": 3, "mnemonic": "vim-style hjkl resize" },
    { "keys": "Ctrl+b Ctrl+k", "action": "Clear pane (reset terminal)", "context": "Tmux", "category": "panes", "difficulty": 3, "mnemonic": "k for kill/clear" }
  ]
}
