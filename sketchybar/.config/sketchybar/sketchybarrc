# https://github.com/FelixKratz/dotfiles

source "$CONFIG_DIR/colors.sh"
source "$CONFIG_DIR/icons.sh" # Loads all defined icons

ITEM_DIR="$CONFIG_DIR/items"
PLUGIN_DIR="$CONFIG_DIR/plugins"

FONT="Hack Nerd Font"

##### Bar Appearance #####
# Configuring the general appearance of the bar.
# These are only some of the options available. For all options see:
# https://felixkratz.github.io/SketchyBar/config/bar
# If you are looking for other colors, see the color picker:
# https://felixkratz.github.io/SketchyBar/config/tricks#color-picker

sketchybar --bar position=top height=32 blur_radius=0 color="$TRANSPARENT"

##### Changing Defaults #####
# We now change some default values, which are applied to all further items.
# For a full list of all available item properties see:
# https://felixkratz.github.io/SketchyBar/config/items

default=(
        padding_left=3
        padding_right=3
        background.color="$ITEM_BG_COLOR"
        background.corner_radius=5
        background.height=25
        icon.color=$WHITE
        icon.y_offset=1
        label.color=$WHITE
        label.y_offset=1
        icon.padding_left=10
        icon.padding_right=4
        label.padding_left=4
        label.padding_right=10
)
sketchybar --default "${default[@]}"
sketchybar --add event aerospace_workspace_change

# Workspace-context visibility dispatcher — hides ambient items (weather, calendar,
# macupdater, clearvpn) on DEV/T workspaces. Single source of truth in
# plugins/workspace_visibility.sh — edit the VIS table there to add items.
sketchybar --add item workspace_visibility center \
           --set workspace_visibility drawing=off updates=on \
                                       script="$PLUGIN_DIR/workspace_visibility.sh" \
           --subscribe workspace_visibility aerospace_workspace_change

##### Left Items #####
source "$ITEM_DIR/space.sh"
# adds layout background for workspaces
sketchybar --add bracket workspaces space.1 space.2 space.B space.D space.F space.M space.N space.T space.E \
           --set workspaces background.color="$PURE_BLACK" \

source "$ITEM_DIR/aerospace_mode.sh"
source "$ITEM_DIR/front_app.sh"
source "$ITEM_DIR/docker.sh"
source "$ITEM_DIR/macupdater.sh"
source "$ITEM_DIR/clearvpn.sh"
source "$ITEM_DIR/voice_server.sh"
source "$ITEM_DIR/calendar.sh"

##### Right Items #####
# Source order = right→left visually (first sourced sits rightmost).
# Layout (right→left):
#   battery | clock | bd_mode | weather | cpu | memory | network | github | mic | volume | obs | spotify | media_block
source "$ITEM_DIR/battery.sh"
source "$ITEM_DIR/clock.sh"
source "$ITEM_DIR/bd_mode.sh"
source "$ITEM_DIR/weather.sh"
source "$ITEM_DIR/cpu.sh"
source "$ITEM_DIR/memory.sh"
source "$ITEM_DIR/network.sh"
# system_health bracket — cpu + memory + network as a "machine state" cluster
sketchybar --add bracket system_health cpu memory network \
           --set system_health background.color="$PURE_BLACK"

source "$ITEM_DIR/github.sh"
source "$ITEM_DIR/mic.sh"
source "$ITEM_DIR/volume.sh"
source "$ITEM_DIR/obs.sh"
# comms bracket — mic + volume + obs as the audio + capture cluster
sketchybar --add bracket comms mic volume obs \
           --set comms background.color="$PURE_BLACK"

source "$ITEM_DIR/spotify.sh"
source "$ITEM_DIR/media_block.sh"

          
           
sketchybar --hotload on

##### Force all scripts to run the first time (never do this in a script) #####
# Note: items use label="" placeholders (not "...") so they render invisibly
# until their plugin's first run populates them. This avoids the well-known
# sketchybar issue where --update from inside the rc doesn't fully re-fire
# plugins that have already been registered, leaving them stuck on the
# placeholder for up to update_freq seconds.
sketchybar --update

# Bootstrap the volume item — it has update_freq=30, so without this trigger
# it would show as a blank box for the first 30s after boot. Fire volume_change
# with the current OS volume so the icon + label populate immediately.
sketchybar --trigger volume_change INFO="$(osascript -e 'output volume of (get volume settings)' 2>/dev/null || echo 50)"

echo "sketchybar configuation loaded.."
