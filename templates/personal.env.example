# Personal dotfiles values — overrides the maintainer's defaults.
#
# Location: ~/.config/dotfiles/personal.env (NOT in this repo)
# Sourced by: bd-apply.sh, bd-lmu-watch.sh, bd-build-slots.sh, and
#   setup.sh's render_launchagents() at install/update time.
#
# Discover your values:
#   aerospace list-monitors                       # macOS display names
#   betterdisplaycli get --identifiers            # BetterDisplay tagIDs
#
# Run `./personalize.sh` for an interactive prompt that writes this file
# for you, or copy this file to ~/.config/dotfiles/personal.env and edit
# by hand.

# -----------------------------------------------------------------------------
# Display hardware (BetterDisplay tagIDs)
# -----------------------------------------------------------------------------
# tagID of your primary built-in display (MacBook Pro internal, etc.)
DOTFILES_BD_DEV_TAG=2

# tagID of your external display (the one bd-apply.sh writes DDC to)
DOTFILES_BD_PORT_TAG=60

# -----------------------------------------------------------------------------
# Monitor names (used by docs / informational; AeroSpace TOML needs manual edit)
# -----------------------------------------------------------------------------
# These are FYI — AeroSpace can't read env vars, so aerospace.toml hard-codes
# monitor names. Set these for personalize.sh to surface them in docs and
# verify your override is consistent with what aerospace.toml expects.
DOTFILES_MONITOR_BUILTIN="Built-in Retina Display"
DOTFILES_MONITOR_EXTERNAL="^PORTRAIT-MONITOR$"

# -----------------------------------------------------------------------------
# Keyboard layout (informational)
# -----------------------------------------------------------------------------
# us | pt-br | uk | de | fr | other
# Used by personalize.sh to suggest which aerospace.toml lines to uncomment
# (PT-BR users have alt-e/alt-n commented out as dead-key conflicts).
DOTFILES_KEYBOARD_LAYOUT=us
