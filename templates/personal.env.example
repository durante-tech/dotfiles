# Personal dotfiles values — overrides the maintainer's defaults.
#
# Location: ~/.config/dotfiles/personal.env (NOT in this repo)
# Sourced by: the bd-* scripts, display-restore.sh, sketchybar bd_mode/obs_action,
#   Raycast display-* wrappers, espanso :sig, and setup.sh's
#   render_launchagents() at install/update time.
#
# Discover your values:
#   aerospace list-monitors                       # macOS display names
#   betterdisplaycli get --identifiers            # BetterDisplay tagIDs
#
# Run `./personalize.sh` for an interactive prompt that writes this file
# for you, or copy this file to ~/.config/dotfiles/personal.env and edit
# by hand.

# -----------------------------------------------------------------------------
# Display hardware (BetterDisplay tagIDs)
# -----------------------------------------------------------------------------
# tagID of your primary built-in display (MacBook Pro internal, etc.)
DOTFILES_BD_DEV_TAG=2

# tagID of your external display (the one bd-apply.sh writes DDC to)
DOTFILES_BD_PORT_TAG=60

# -----------------------------------------------------------------------------
# Monitor names (substituted into aerospace.toml by render-aerospace.sh)
# -----------------------------------------------------------------------------
# AeroSpace TOML can't read env vars, so render-aerospace.sh sed-substitutes
# these into aerospace.toml.template → aerospace.toml at install/update time.
# For a single-display laptop, set EXTERNAL to the same value as BUILTIN.
DOTFILES_MONITOR_BUILTIN="Built-in Retina Display"
DOTFILES_MONITOR_EXTERNAL="PORTRAIT-MONITOR"

# -----------------------------------------------------------------------------
# Keyboard layout (informational)
# -----------------------------------------------------------------------------
# us | pt-br | uk | de | fr | other
# Used by personalize.sh to suggest which aerospace.toml lines to uncomment
# (PT-BR users have alt-e/alt-n commented out as dead-key conflicts).
DOTFILES_KEYBOARD_LAYOUT=us

# -----------------------------------------------------------------------------
# Display layout (displayplacer specs — only for display-restore.sh users)
# -----------------------------------------------------------------------------
# Display UUIDs are machine-specific; without this override display-restore.sh
# uses the maintainer's rig and no-ops on yours. Discover specs: `displayplacer list`.
# Newline-separated per-screen specs:
#DOTFILES_DISPLAY_LAYOUT='id:YOUR-BUILTIN-UUID res:1728x1117 hz:120 color_depth:8 enabled:true scaling:on origin:(0,0) degree:0
#id:YOUR-EXTERNAL-UUID res:1920x1080 hz:60 color_depth:8 enabled:true scaling:on origin:(1728,37) degree:0'

# Resolution for `display-restore.sh --solo` (single-display/clamshell; UUID is
# detected live so no override needed for it). Ignored by every other profile.
#DOTFILES_DISPLAY_SOLO_RES=2560x1440

# -----------------------------------------------------------------------------
# Weather location (sketchybar weather plugin)
# -----------------------------------------------------------------------------
# wttr.in location; leave unset for IP-based auto-detection.
#DOTFILES_WEATHER_LOCATION="Sao+Paulo"

# -----------------------------------------------------------------------------
# Repo location (only needed if the repo is NOT at ~/dotfiles)
# -----------------------------------------------------------------------------
# Daemon contexts (launchd, sketchybar, Raycast) never see shell exports, so
# scripts source this file before resolving the repo path.
#DOTFILES_DIR="$HOME/dotfiles"

# -----------------------------------------------------------------------------
# Email signature (espanso :sig) — falls back to git config when unset
# -----------------------------------------------------------------------------
#DOTFILES_SIG_NAME="Your Name"
#DOTFILES_SIG_EMAIL="you@example.com"
